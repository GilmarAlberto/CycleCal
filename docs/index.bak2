<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>CycleCal</title>

        <link rel="manifest" href="manifest.json" />
        <meta name="theme-color" content="#2FAF8A" />

        <link rel="icon" href="icon-256.png" type="image/png" />

        <!-- Versão 1.8.2 -->

        <style>
            :root {
                --birthday-color: #d4af37;
            }

            body {
                font-family: Arial, sans-serif;
                background: #f5f7f6;
                margin: 0;
                padding: 20px;
            }

            .container {
                max-width: 500px;
                margin: auto;
                background: white;
                padding: 20px;
                border-radius: 16px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            }

            .header {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .header-left {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .logo {
                width: 40px;
                height: 40px;
            }

            h1 {
                margin: 0;
                font-size: 26px;
            }

            .version {
                font-size: 12px;
                color: gray;
                margin-left: 6px;
            }

            .title-group {
                display: flex;
                flex-direction: column;
            }

            .title-line {
                display: flex;
                align-items: baseline;
                gap: 6px;
            }

            .btn-hoje {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                border: none;
                background: black;
                color: white;
                font-weight: bold;
                font-size: 14px;
                cursor: pointer;

                display: flex;
                align-items: center;
                justify-content: center;

                padding: 0;
                line-height: 1;
            }

            .line {
                margin: 15px 0;
                border-bottom: 2px solid #eee;
            }

            .controls {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 15px;
            }

            button {
                padding: 6px 12px;
                font-size: 16px;
            }

            .controls button {
                min-height: 44px;
                width: 44px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .calendar {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                gap: 8px;
            }

            .day,
            .header-day {
                text-align: center;
                padding: 12px 0;
                border-radius: 8px;
            }

            .header-day {
                font-weight: bold;
                background: #f0f0f0;
            }

            .day {
                background: #fafafa;
                border: 1px solid #eee;
                position: relative;
            }

            .day.birthday {
                border: 2px solid var(--birthday-color);
            }

            .day.birthday::after {
                content: "🎂";
                position: absolute;
                bottom: 4px;
                right: 4px;
                font-size: 12px;
            }

            .day.folga {
                background: #e6f7f1;
                border: 2px solid #2faf8a;
            }

            .day.holiday {
                background: #ffeaea;
                border: 2px solid #c62828;
            }

            .day.cultural {
                background: #f3e8ff;
                border: 2px solid #8e44ad;
            }

            .day.vacation {
                background: repeating-linear-gradient(
                    45deg,
                    #f5f5f5,
                    #f5f5f5 4px,
                    #e0e0e0 4px,
                    #e0e0e0 8px
                );
                border: 2px solid #9e9e9e;
            }

            .day.today span {
                display: inline-block;
                width: 28px;
                height: 28px;
                line-height: 28px;
                border-radius: 50%;
                background: black;
                color: white;
                font-weight: bold;
            }

            .footer {
                margin-top: 20px;
                font-size: 12px;
                color: gray;
            }

            .legend {
                margin-top: 8px;
                color: #444;
                display: none;
            }

            .legend-box {
                display: inline-block;
                width: 14px;
                height: 14px;
                border-radius: 3px;
                margin-right: 6px;
                vertical-align: middle;
            }

            .legend-box.vacation {
                background: repeating-linear-gradient(
                    45deg,
                    #f5f5f5,
                    #f5f5f5 4px,
                    #e0e0e0 4px,
                    #e0e0e0 8px
                );
                border: 1px solid #9e9e9e;
            }

            .footer .holidays {
                margin-top: 10px;
                color: #444;
            }

            #controle-folgas {
                font-size: 12px;
                color: gray;
                margin-top: 2px;
            }

            .calendar-transition {
                opacity: 0;
                transform: translateY(4px);
            }

            .calendar-transition-active {
                transition:
                    opacity 140ms ease-out,
                    transform 140ms ease-out;
                opacity: 1;
                transform: translateY(0);
            }

            .periodo {
                flex: 1;
                min-height: 44px;
                padding: 0 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                font-size: 1.1rem;
                cursor: pointer;
                user-select: none;
                border-radius: 8px;
                transition:
                    background 0.15s ease,
                    transform 0.08s ease;
            }

            .periodo:active {
                transform: scale(0.97);
            }

            @media (hover: hover) {
                .periodo:hover {
                    background: rgba(0, 0, 0, 0.05);
                }
            }

            /* Bottom Sheet Overlay (base) */
            #pickerOverlay {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.35);
                display: flex;
                justify-content: center;
                align-items: flex-end;
                z-index: 999;
            }

            #pickerOverlay[hidden] {
                display: none !important;
            }

            /* Bottom Sheet (visual + animação) */
            .picker-sheet {
                width: 100%;
                max-width: 500px;
                background: #ffffff;
                border-radius: 16px 16px 0 0;
                padding: 20px;

                /* Estado inicial (fechado) */
                transform: translateY(100%);
                transition: transform 220ms cubic-bezier(0.22, 0.61, 0.36, 1);
            }

            .picker-handle {
                width: 36px;
                height: 4px;
                background: #d0d0d0;
                border-radius: 3px;
                margin: 0 auto 12px auto;
            }

            .month-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
                margin-top: 10px;
            }

            .month-item {
                padding: 12px;
                text-align: center;
                border-radius: 8px;
                background: #f3f4f4;
                font-weight: 600;
                border: 1px solid #e6e6e6;
            }

            .month-item.active {
                background: #2faf8a;
                color: white;
            }

            /* Quando estiver ativo */
            #pickerOverlay.active .picker-sheet {
                transform: translateY(0);
            }

            #anoTexto {
                margin-left: 6px;
            }

            #mesTexto,
            #anoTexto {
                cursor: pointer;
            }

            .periodo span {
                padding: 4px 2px;
            }

            .day span {
                position: relative;
                z-index: 1;
            }

            .day.birthday::after {
                z-index: 2;
            }

            .setup-modal {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.35);

                justify-content: center;
                align-items: center;

                z-index: 1000;
            }

            .setup-box {
                background: white;
                padding: 20px;
                border-radius: 12px;
                width: 280px;

                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            }
        </style>
    </head>

    <body>
        <div class="container">
            <div class="header">
                <div class="header-left">
                    <img src="icon-256.png" class="logo" />

                    <div class="title-group">
                        <div class="title-line">
                            <h1>CycleCal</h1>
                            <span class="version">v1.8.2</span>
                        </div>

                        <div id="userGreeting"></div>

                        <div id="controle-folgas">Controle de Escalas e Folgas</div>
                    </div>
                </div>

                <button class="btn-hoje" id="btnHoje" onclick="irParaHoje()"></button>
            </div>

            <div class="line"></div>

            <div class="controls">
                <button onclick="mesAnterior()">◀</button>

                <div class="periodo">
                    <span id="mesTexto"></span>
                    <span id="anoTexto"></span>
                </div>

                <button onclick="proximoMes()">▶</button>
            </div>

            <div class="calendar" id="calendario"></div>

            <div style="margin-top: 15px; text-align: center">
                <button id="btnFerias">Registrar Férias</button>
                <button id="btnSetup">Setup ⚙</button>

                <div id="formFerias" style="display: none; margin-top: 10px">
                    <label>Início:</label>
                    <input type="date" id="feriasInicio" />

                    <label>Fim:</label>
                    <input type="date" id="feriasFim" />

                    <button id="salvarFeriasBtn">Salvar</button>
                </div>

                <div id="listaFerias" style="margin-top: 10px"></div>
            </div>

            <div class="footer">
                <div id="infoEscala"></div>
                <div id="footerBase"></div>

                <div class="legend" id="birthdayLegend">🎂 Aniversário</div>

                <div class="legend" id="vacationLegend">
                    <span class="legend-box vacation"></span> Férias
                </div>

                <div class="holidays" id="listaFeriados"></div>
            </div>
        </div>

        <script>
            const AREAS = [
                { value: "supermercado", label: "Supermercado / Varejo" },
                { value: "seguranca", label: "Segurança Pública" },
                { value: "hospital", label: "Hospital / Saúde" },
                { value: "industria", label: "Indústria" },
                { value: "outros", label: "Outros" },
            ];

            const AREA_PRESETS = {
                seguranca: {
                    scale_type: "plantao",
                    scale_pattern: "24x72",
                },
                hospital: {
                    scale_type: "plantao",
                    scale_pattern: "12x36",
                },
                supermercado: {
                    scale_type: "semanal",
                    scale_pattern: "6x1",
                },
                industria: {
                    scale_type: "turno",
                    scale_pattern: "5x1",
                },
            };

            const AREAS_WITHOUT_DSR = ["seguranca", "hospital"];

            const mesesAbreviados = [
                "JAN",
                "FEV",
                "MAR",
                "ABR",
                "MAI",
                "JUN",
                "JUL",
                "AGO",
                "SET",
                "OUT",
                "NOV",
                "DEZ",
            ];

            let anoAtual;
            let mesAtual;
            let yearBlockStart;
            let vacations = [];
            let userModifiedScale = false;
            let isApplyingPreset = false;
            let setupModal;

            function initUser() {
                const stored = localStorage.getItem("cyclecal_user");

                if (!stored) {
                    const user = {
                        version: 1,
                        updated_at: "",
                        profile: {
                            user_id: crypto.randomUUID(),
                            name: "",
                            area: "",
                            birthday: "",
                            created_at: new Date().toISOString(),
                        },
                        settings: {
                            base_date: "",
                            scale_type: "",
                            scale_pattern: "",
                            dsr: 0,
                        },
                        preferences: {
                            theme: "auto",
                        },
                        vacations: [],
                    };

                    localStorage.setItem("cyclecal_user", JSON.stringify(user));
                }
            }

            function getUser() {
                return JSON.parse(localStorage.getItem("cyclecal_user"));
            }

            function saveUser(user) {
                user.updated_at = new Date().toISOString();
                localStorage.setItem("cyclecal_user", JSON.stringify(user));
            }

            function renderAreaSelect() {
                const select = document.getElementById("areaSelect");

                if (!select) return;

                select.innerHTML = "";

                AREAS.forEach((area) => {
                    const option = document.createElement("option");
                    option.value = area.value;
                    option.textContent = area.label;
                    select.appendChild(option);
                });

                const user = getUser();
                select.value = user.profile.area || "outros";
            }

            function applyAreaPreset(area) {
                const preset = AREA_PRESETS[area];
                if (!preset) return;

                isApplyingPreset = true;

                document.getElementById("setupScaleType").value = preset.scale_type;
                document.getElementById("setupScalePattern").value = preset.scale_pattern;

                isApplyingPreset = false;
            }

            function getBaseDate() {
                const user = getUser();

                if (user.settings.base_date) {
                    return new Date(user.settings.base_date);
                }

                // fallback padrão atual
                return new Date(2026, 1, 15);
            }

            function setBaseDate(dateStr) {
                const user = getUser();

                user.settings.base_date = dateStr;

                saveUser(user);

                baseFolgaDomingo = new Date(dateStr);

                gerarCalendario(anoAtual, mesAtual);
            }

            function alterarBaseDate() {
                const novaData = prompt("Informe a nova data base (AAAA-MM-DD):");

                if (!novaData) return;

                setBaseDate(novaData);
            }

            function setScaleType(type) {
                const user = getUser();

                user.settings.scale_type = type;

                saveUser(user);
            }

            function alterarTipoEscala() {
                const tipo = prompt("Tipo de escala (ex: semanal, plantao)");

                if (!tipo) return;

                setScaleType(tipo);
            }

            function setScalePattern(pattern) {
                const user = getUser();

                user.settings.scale_pattern = pattern;

                saveUser(user);
            }

            function alterarPadraoEscala() {
                const pattern = prompt("Padrão da escala (ex: 7, 5x1, 12x36)");

                if (!pattern) return;

                setScalePattern(pattern);
            }

            function setTheme(theme) {
                const user = getUser();

                user.preferences.theme = theme;

                saveUser(user);
            }

            function alterarTema() {
                const tema = prompt("Tema (auto, dark, light)");

                if (!tema) return;

                setTheme(tema);
            }

            function salvarFerias() {
                localStorage.setItem("cyclecal_vacations", JSON.stringify(vacations));
            }

            function carregarFerias() {
                const saved = localStorage.getItem("cyclecal_vacations");

                if (saved) {
                    vacations = JSON.parse(saved);
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                initUser();

                const user = getUser();

                if (!user.profile.area) {
                    user.profile.area = "outros";
                    saveUser(user);
                }

                renderAreaSelect();

                const areaSelect = document.getElementById("areaSelect");

                setupModal = document.getElementById("setupModal");

                areaSelect.addEventListener("change", (e) => {
                    const user = getUser();
                    user.profile.area = e.target.value;
                    saveUser(user);

                    userModifiedScale = false;
                    applyAreaPreset(e.target.value);

                    const dsrField = document.getElementById("setupDSR").parentElement;

                    if (AREAS_WITHOUT_DSR.includes(e.target.value)) {
                        dsrField.style.display = "none";
                        document.getElementById("setupDSR").value = "0";
                    } else {
                        dsrField.style.display = "";
                    }
                });

                document.getElementById("setupScaleType").addEventListener("input", () => {
                    if (isApplyingPreset) return;
                    userModifiedScale = true;
                });

                document.getElementById("setupScalePattern").addEventListener("input", () => {
                    if (isApplyingPreset) return;
                    userModifiedScale = true;
                });

                verificarPerfil();
                atualizarSaudacao();
                atualizarFooterBase();

                const birthdayInput = document.getElementById("setupBirthday");

                if (birthdayInput) {
                    birthdayInput.addEventListener("input", function (e) {
                        let v = e.target.value.replace(/\D/g, "");

                        if (v.length > 4) v = v.slice(0, 4);

                        if (v.length >= 3) {
                            v = v.slice(0, 2) + "/" + v.slice(2);
                        }

                        e.target.value = v;
                    });
                }

                baseFolgaDomingo = getBaseDate();

                const hoje = new Date();
                anoAtual = hoje.getFullYear();
                mesAtual = hoje.getMonth();

                gerarCalendario(anoAtual, mesAtual);
                document.getElementById("btnHoje").innerText = hoje.getDate();

                document.getElementById("btnSetup").onclick = function () {
                    userModifiedScale = false;
                    mostrarSetup();
                };

                document.getElementById("setupFechar").onclick = function () {
                    setupModal.style.display = "none";
                };

                document.getElementById("setupSalvar").onclick = function () {
                    const baseDate = document.getElementById("setupBaseDate").value;
                    const userName = document.getElementById("setupUserName").value;

                    const birthdayInput = document.getElementById("setupBirthday").value;

                    let birthday = "";

                    if (birthdayInput && birthdayInput.includes("/")) {
                        const [d, m] = birthdayInput.split("/");

                        if (d && m) {
                            birthday = `2000-${m.padStart(2, "0")}-${d.padStart(2, "0")}`;
                        }
                    }

                    if (!userName) {
                        alert("Como deseja ser chamado?");
                        return;
                    }

                    if (!baseDate) {
                        alert("Informe a data base da escala.");
                        return;
                    }

                    const user = getUser();
                    user.profile.name = userName;
                    user.profile.birthday = birthday;

                    user.profile.area = document.getElementById("areaSelect").value || "outros";

                    user.settings.base_date = baseDate;

                    user.settings.scale_type = document.getElementById("setupScaleType").value;

                    user.settings.scale_pattern =
                        document.getElementById("setupScalePattern").value;

                    user.settings.dsr = Number(document.getElementById("setupDSR").value);

                    user.preferences.theme = document.getElementById("setupTheme").value;

                    saveUser(user);

                    atualizarSaudacao();

                    atualizarFooterBase();

                    baseFolgaDomingo = getBaseDate();

                    gerarCalendario(anoAtual, mesAtual);

                    setupModal.style.display = "none";
                };

                // ===== PICKER + SWIPE (UNIFICADO) =====

                overlay = document.getElementById("pickerOverlay");

                const mesEl = document.getElementById("mesTexto");
                const anoEl = document.getElementById("anoTexto");

                function openPicker() {
                    renderMonthPicker();
                    overlay.hidden = false;

                    requestAnimationFrame(() => {
                        overlay.classList.add("active");
                    });
                }

                mesEl.addEventListener("click", openPicker);

                anoEl.addEventListener("click", function (e) {
                    e.stopPropagation();

                    renderYearPicker();
                    overlay.hidden = false;

                    requestAnimationFrame(() => {
                        overlay.classList.add("active");
                    });
                });

                overlay.addEventListener("click", function (e) {
                    if (e.target === overlay) {
                        closePicker();
                    }
                });

                // SWIPE
                let touchStartX = 0;
                let touchStartY = 0;

                const calendarioEl = document.getElementById("calendario");

                if (calendarioEl) {
                    calendarioEl.addEventListener(
                        "touchstart",
                        function (e) {
                            const touch = e.changedTouches[0];
                            touchStartX = touch.clientX;
                            touchStartY = touch.clientY;
                        },
                        { passive: true },
                    );

                    calendarioEl.addEventListener(
                        "touchend",
                        function (e) {
                            const touch = e.changedTouches[0];

                            const deltaX = touch.clientX - touchStartX;
                            const deltaY = touch.clientY - touchStartY;

                            const threshold = calendarioEl.clientWidth * 0.18;

                            if (Math.abs(deltaY) > Math.abs(deltaX)) return;

                            if (deltaX > threshold) mesAnterior();
                            else if (deltaX < -threshold) proximoMes();
                        },
                        { passive: true },
                    );
                }
            });

            function irParaHoje() {
                const agora = new Date();
                anoAtual = agora.getFullYear();
                mesAtual = agora.getMonth();
                document.getElementById("btnHoje").innerText = agora.getDate();
                gerarCalendario(anoAtual, mesAtual);
            }

            let baseFolgaDomingo;

            /* ===== FERIADOS FIXOS ===== */
            /* (mantido exatamente igual ao original) */

            const feriadosNacionais = [
                { dia: 1, mes: 0, nome: "Confraternização Universal" },
                { dia: 21, mes: 3, nome: "Tiradentes" },
                { dia: 1, mes: 4, nome: "Dia do Trabalho" },
                { dia: 7, mes: 8, nome: "Independência do Brasil" },
                { dia: 12, mes: 9, nome: "Nossa Senhora Aparecida" },
                { dia: 2, mes: 10, nome: "Finados" },
                { dia: 15, mes: 10, nome: "Proclamação da República" },
                { dia: 20, mes: 10, nome: "Dia da Consciência Negra" },
                { dia: 25, mes: 11, nome: "Natal" },
            ];

            const feriadosCuritiba = [{ dia: 8, mes: 8, nome: "Nossa Senhora da Luz dos Pinhais" }];

            const feriadosFixos = [...feriadosNacionais, ...feriadosCuritiba];

            /* ===== restante do código (inalterado) ===== */

            function calcularPascoa(ano) {
                const a = ano % 19;
                const b = Math.floor(ano / 100);
                const c = ano % 100;
                const d = Math.floor(b / 4);
                const e = b % 4;
                const f = Math.floor((b + 8) / 25);
                const g = Math.floor((b - f + 1) / 3);
                const h = (19 * a + b - d - g + 15) % 30;
                const i = Math.floor(c / 4);
                const k = c % 4;
                const l = (32 + 2 * e + 2 * i - h - k) % 7;
                const m = Math.floor((a + 11 * h + 22 * l) / 451);

                const mes = Math.floor((h + l - 7 * m + 114) / 31);
                const dia = ((h + l - 7 * m + 114) % 31) + 1;

                return new Date(ano, mes - 1, dia);
            }

            function gerarFeriadosMoveis(ano) {
                const pascoa = calcularPascoa(ano);

                const sextaSanta = new Date(pascoa);
                sextaSanta.setDate(pascoa.getDate() - 2);

                const corpusChristi = new Date(pascoa);
                corpusChristi.setDate(pascoa.getDate() + 60);

                return [
                    {
                        dia: sextaSanta.getDate(),
                        mes: sextaSanta.getMonth(),
                        nome: "Sexta-feira Santa",
                    },
                    { dia: pascoa.getDate(), mes: pascoa.getMonth(), nome: "Páscoa" },
                    {
                        dia: corpusChristi.getDate(),
                        mes: corpusChristi.getMonth(),
                        nome: "Corpus Christi",
                    },
                ];
            }

            function gerarCarnaval(ano) {
                const pascoa = calcularPascoa(ano);

                const eventos = [];

                const offsets = [
                    { offset: -51, nome: "Sexta-feira de Carnaval" },
                    { offset: -50, nome: "Sábado de Carnaval" },
                    { offset: -49, nome: "Domingo de Carnaval" },
                    { offset: -48, nome: "Segunda-feira de Carnaval" },
                    { offset: -47, nome: "Terça-feira de Carnaval" },
                    { offset: -46, nome: "Quarta-feira de Cinzas (até 14h)" },
                ];

                offsets.forEach((item) => {
                    const data = new Date(pascoa);
                    data.setDate(pascoa.getDate() + item.offset);

                    eventos.push({
                        dia: data.getDate(),
                        mes: data.getMonth(),
                        nome: item.nome,
                    });
                });

                return eventos;
            }

            const prioridadeEventos = ["vacation", "folga", "holiday", "cultural", "birthday"];

            function resolverEvento(eventos) {
                for (const tipo of prioridadeEventos) {
                    if (eventos.includes(tipo)) {
                        return tipo;
                    }
                }

                return null;
            }

            function ehFeriado(data, lista) {
                return lista.find((f) => f.dia === data.getDate() && f.mes === data.getMonth());
            }

            function listarFeriadosDoMes(ano, mes, lista) {
                const listaDiv = document.getElementById("listaFeriados");
                listaDiv.innerHTML = "";

                const feriadosDoMes = lista
                    .filter((f) => f.mes === mes)
                    .sort((a, b) => a.dia - b.dia);

                feriadosDoMes.forEach((f) => {
                    const div = document.createElement("div");
                    div.innerText =
                        `${String(f.dia).padStart(2, "0")}/` +
                        `${String(f.mes + 1).padStart(2, "0")} – ${f.nome}`;
                    listaDiv.appendChild(div);
                });
            }

            function ehFolga(data) {
                const user = getUser();
                const dsr = Number(user.settings.dsr || 0);
                const area = user.profile.area;

                // 🚫 ignora DSR para essas áreas
                if (!AREAS_WITHOUT_DSR.includes(area)) {
                    if (data.getDay() === dsr) return true;
                }

                // 🔁 ciclo de domingo (mantido)
                if (data.getDay() === 0) {
                    const diff = Math.floor(
                        (Date.UTC(data.getFullYear(), data.getMonth(), data.getDate()) -
                            Date.UTC(
                                baseFolgaDomingo.getFullYear(),
                                baseFolgaDomingo.getMonth(),
                                baseFolgaDomingo.getDate(),
                            )) /
                            86400000,
                    );

                    const semanas = Math.floor(diff / 7);
                    return semanas % 3 === 0;
                }

                return false;
            }

            function ehFerias(data) {
                const dateStr =
                    data.getFullYear() +
                    "-" +
                    String(data.getMonth() + 1).padStart(2, "0") +
                    "-" +
                    String(data.getDate()).padStart(2, "0");

                return vacations.some((v) => dateStr >= v.start && dateStr <= v.end);
            }

            function gerarCalendario(ano, mes) {
                const mesEl = document.getElementById("mesTexto");
                const anoEl = document.getElementById("anoTexto");

                mesEl.textContent = mesesAbreviados[mes];
                anoEl.textContent = ano;

                const legend = document.getElementById("birthdayLegend");

                if (mes === 6) {
                    legend.style.display = "block";
                } else {
                    legend.style.display = "none";
                }

                const vacationLegend = document.getElementById("vacationLegend");

                const inicioMes = new Date(ano, mes, 1);
                const fimMes = new Date(ano, mes + 1, 0);

                const temFeriasNoMes = vacations.some((v) => {
                    const inicio = new Date(v.start);
                    const fim = new Date(v.end);

                    return inicio <= fimMes && fim >= inicioMes;
                });

                vacationLegend.style.display = temFeriasNoMes ? "block" : "none";

                const calendario = document.getElementById("calendario");
                // Início da microtransição
                calendario.classList.remove("calendar-transition-active");
                calendario.classList.add("calendar-transition");
                calendario.innerHTML = "";

                const diasSemana = ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"];

                diasSemana.forEach((d) => {
                    const el = document.createElement("div");
                    el.className = "header-day";
                    el.innerText = d;
                    calendario.appendChild(el);
                });

                const primeiroDia = new Date(ano, mes, 1);
                const inicio = primeiroDia.getDay();
                const agora = new Date();
                const diasNoMes = new Date(ano, mes + 1, 0).getDate();

                const feriadosMoveis = gerarFeriadosMoveis(ano);
                const carnaval = gerarCarnaval(ano);

                const todosFeriados = [...feriadosFixos, ...feriadosMoveis];

                for (let i = 0; i < inicio; i++) {
                    calendario.appendChild(document.createElement("div"));
                }

                const user = getUser();

                let aniversario = null;

                if (user.profile.birthday) {
                    const [y, m, d] = user.profile.birthday.split("-");
                    aniversario = ajustarAniversario(Number(d), Number(m) - 1, ano);
                }

                for (let dia = 1; dia <= diasNoMes; dia++) {
                    const data = new Date(ano, mes, dia);
                    const el = document.createElement("div");
                    el.className = "day";

                    const span = document.createElement("span");
                    span.innerText = dia;
                    el.appendChild(span);

                    const eventos = eventosDoDia(data, todosFeriados, carnaval, aniversario);

                    const principal = resolverEvento(eventos);

                    if (principal) {
                        el.classList.add(principal);
                    }

                    if (eventos.includes("birthday")) {
                        el.classList.add("birthday");
                    }

                    if (
                        dia === agora.getDate() &&
                        mes === agora.getMonth() &&
                        ano === agora.getFullYear()
                    ) {
                        el.classList.add("today");
                    }

                    calendario.appendChild(el);
                }

                listarFeriadosDoMes(ano, mes, [...todosFeriados, ...carnaval]);
                // Ativar microtransição
                void calendario.offsetWidth;
                calendario.classList.add("calendar-transition-active");
                calendario.classList.remove("calendar-transition");
            }

            function proximoMes() {
                mesAtual++;
                if (mesAtual > 11) {
                    mesAtual = 0;
                    anoAtual++;
                }
                gerarCalendario(anoAtual, mesAtual);
            }

            function mesAnterior() {
                mesAtual--;
                if (mesAtual < 0) {
                    mesAtual = 11;
                    anoAtual--;
                }
                gerarCalendario(anoAtual, mesAtual);
            }

            function renderMonthPicker() {
                const sheet = document.getElementById("pickerSheet");

                sheet.innerHTML = "";

                const handle = document.createElement("div");
                handle.className = "picker-handle";
                sheet.appendChild(handle);

                const grid = document.createElement("div");
                grid.className = "month-grid";

                mesesAbreviados.forEach((mes, index) => {
                    const item = document.createElement("div");
                    item.className = "month-item";
                    item.innerText = mes;

                    if (index === mesAtual) {
                        item.classList.add("active");
                    }

                    item.addEventListener("click", () => {
                        sheet.querySelectorAll(".month-item.active").forEach((el) => {
                            el.classList.remove("active");
                        });
                        item.classList.add("active");

                        setTimeout(() => {
                            mesAtual = index;
                            gerarCalendario(anoAtual, mesAtual);
                            closePicker();
                        }, 120);
                    });

                    grid.appendChild(item);
                });

                sheet.appendChild(grid);
            }

            function renderYearPicker() {
                const sheet = document.getElementById("pickerSheet");

                sheet.innerHTML = "";

                const handle = document.createElement("div");
                handle.className = "picker-handle";
                sheet.appendChild(handle);

                if (yearBlockStart === undefined) {
                    yearBlockStart = Math.floor(anoAtual / 12) * 12;
                }

                const startYear = yearBlockStart;

                const header = document.createElement("div");
                header.style.display = "flex";
                header.style.justifyContent = "space-between";
                header.style.alignItems = "center";
                header.style.marginBottom = "10px";

                const prev = document.createElement("div");
                prev.innerText = "◀";
                prev.style.cursor = "pointer";
                prev.style.padding = "6px";

                const title = document.createElement("div");
                title.innerText = `${startYear} - ${startYear + 11}`;
                title.style.fontWeight = "600";

                const next = document.createElement("div");
                next.innerText = "▶";
                next.style.cursor = "pointer";
                next.style.padding = "6px";

                header.appendChild(prev);
                header.appendChild(title);
                header.appendChild(next);

                sheet.appendChild(header);

                prev.addEventListener("click", () => {
                    yearBlockStart -= 12;
                    renderYearPicker();
                });

                next.addEventListener("click", () => {
                    yearBlockStart += 12;
                    renderYearPicker();
                });

                const grid = document.createElement("div");
                grid.className = "month-grid";

                for (let i = 0; i < 12; i++) {
                    const year = startYear + i;

                    const item = document.createElement("div");
                    item.className = "month-item";
                    item.innerText = year;

                    if (year === anoAtual) {
                        item.classList.add("active");
                    }

                    item.addEventListener("click", () => {
                        item.classList.add("active");

                        setTimeout(() => {
                            anoAtual = year;
                            yearBlockStart = undefined;
                            gerarCalendario(anoAtual, mesAtual);
                            closePicker();
                        }, 120);
                    });

                    grid.appendChild(item);
                }

                sheet.appendChild(grid);

                let startX = 0;

                sheet.ontouchstart = (e) => {
                    startX = e.changedTouches[0].clientX;
                };

                sheet.ontouchend = (e) => {
                    const deltaX = e.changedTouches[0].clientX - startX;

                    const threshold = sheet.clientWidth * 0.18;

                    if (deltaX > threshold) {
                        yearBlockStart -= 12;
                        renderYearPicker();
                    } else if (deltaX < -threshold) {
                        yearBlockStart += 12;
                        renderYearPicker();
                    }
                };
            }

            /* ===== KEYBOARD NAVIGATION v1.3.5 ===== */

            document.addEventListener("keydown", function (e) {
                if (e.target.tagName === "INPUT") return;

                switch (e.key) {
                    case "ArrowLeft":
                        mesAnterior();
                        break;

                    case "ArrowRight":
                        proximoMes();
                        break;

                    case "ArrowUp":
                        anoAtual--;
                        gerarCalendario(anoAtual, mesAtual);
                        break;

                    case "ArrowDown":
                        anoAtual++;
                        gerarCalendario(anoAtual, mesAtual);
                        break;

                    case "PageUp":
                        e.preventDefault();
                        mesAnterior();
                        break;

                    case "PageDown":
                        e.preventDefault();
                        proximoMes();
                        break;

                    case "Home":
                        e.preventDefault();
                        irParaHoje();
                        break;
                }
            });

            /* ===== SWIPE NAVIGATION v1.2.3 ===== */

            let swipeLocked = false;

            if ("serviceWorker" in navigator) {
                navigator.serviceWorker.register("sw.js").then((reg) => {
                    reg.addEventListener("updatefound", () => {
                        const newWorker = reg.installing;
                        if (!newWorker) return;

                        newWorker.addEventListener("statechange", () => {
                            if (
                                newWorker.state === "installed" &&
                                navigator.serviceWorker.controller
                            ) {
                                window.location.reload();
                            }
                        });
                    });
                });
            }

            /* ===== Bottom Sheet v1.4.3 ===== */

            let overlay;

            function closePicker() {
                overlay.classList.remove("active");

                overlay.addEventListener(
                    "transitionend",
                    () => {
                        overlay.hidden = true;
                    },
                    { once: true },
                );
            }

            function ajustarAniversario(dia, mes, ano) {
                // fevereiro = 1 no JavaScript
                if (dia === 29 && mes === 1) {
                    const diasFev = new Date(ano, 2, 0).getDate();

                    if (diasFev === 28) {
                        return { dia: 28, mes: 1 };
                    }
                }

                return { dia, mes };
            }

            function eventosDoDia(data, todosFeriados, carnaval, aniversario) {
                const eventos = [];

                if (ehFolga(data)) eventos.push("folga");

                if (ehFerias(data)) eventos.push("vacation");

                if (ehFeriado(data, todosFeriados)) eventos.push("holiday");

                if (ehFeriado(data, carnaval)) eventos.push("cultural");

                if (
                    aniversario &&
                    data.getDate() === aniversario.dia &&
                    data.getMonth() === aniversario.mes
                ) {
                    eventos.push("birthday");
                }

                return eventos;
            }

            document.getElementById("btnFerias").addEventListener("click", function () {
                const form = document.getElementById("formFerias");

                form.style.display = form.style.display === "none" ? "block" : "none";
            });

            document.getElementById("salvarFeriasBtn").addEventListener("click", function () {
                const inicio = document.getElementById("feriasInicio").value;
                const fim = document.getElementById("feriasFim").value;

                if (!inicio || !fim) {
                    alert("Informe as datas.");
                    return;
                }

                if (fim < inicio) {
                    alert("Data final inválida.");
                    return;
                }

                vacations.push({
                    start: inicio,
                    end: fim,
                });

                salvarFerias();

                gerarCalendario(anoAtual, mesAtual);

                renderListaFerias();

                document.getElementById("formFerias").style.display = "none";
            });

            function formatarData(dataISO) {
                const [ano, mes, dia] = dataISO.split("-");
                return `${dia}/${mes}/${ano}`;
            }

            function renderListaFerias() {
                const container = document.getElementById("listaFerias");
                container.innerHTML = "";

                vacations.forEach((v, index) => {
                    const item = document.createElement("div");

                    item.innerHTML =
                        formatarData(v.start) +
                        " → " +
                        formatarData(v.end) +
                        ' <button onclick="removerFerias(' +
                        index +
                        ')">Remover</button>';

                    container.appendChild(item);
                });
            }

            function removerFerias(index) {
                vacations.splice(index, 1);

                salvarFerias();

                gerarCalendario(anoAtual, mesAtual);

                renderListaFerias();
            }

            function verificarPerfil() {
                const user = getUser();

                if (!user.profile.name || !user.settings.base_date) {
                    setTimeout(() => mostrarSetup(), 0);
                }
            }

            function atualizarSaudacao() {
                const user = getUser();
                const el = document.getElementById("userGreeting");

                if (!user.profile.name) return;

                const hoje = new Date();

                let isAniversario = false;

                if (user.profile.birthday) {
                    const [y, m, d] = user.profile.birthday.split("-");

                    if (hoje.getDate() === Number(d) && hoje.getMonth() === Number(m) - 1) {
                        isAniversario = true;
                    }
                }

                if (isAniversario) {
                    el.innerText = `Feliz Aniversário, ${user.profile.name}! 🎂`;
                } else {
                    el.innerText = `Olá ${user.profile.name}`;
                }
            }

            function atualizarFooterBase() {
                const el = document.getElementById("footerBase");
                const user = getUser();

                const partes = [];

                // 📅 BASE
                if (user.settings.base_date) {
                    const [y, m, d] = user.settings.base_date.split("-");
                    partes.push(`Folga Domingo: ${d}/${m}/${y}`);
                }

                // 📆 DSR
                const diasSemana = [
                    "Domingo",
                    "Segunda",
                    "Terça",
                    "Quarta",
                    "Quinta",
                    "Sexta",
                    "Sábado",
                ];

                const dsr = Number(user.settings.dsr ?? 0);
                partes.push(`DSR: ${diasSemana[dsr]}`);

                // 🎂 ANIVERSÁRIO
                if (user.profile.birthday) {
                    const [y, m, d] = user.profile.birthday.split("-");
                    partes.push(`🎂 ${d}/${m}`);
                }

                el.innerText = partes.join(" | ");
            }

            function preencherSetup() {
                const user = getUser();

                document.getElementById("setupUserName").value = user.profile.name || "";

                const birthday = user.profile.birthday;

                if (birthday && birthday.includes("-")) {
                    const parts = birthday.split("-");

                    if (parts.length === 3) {
                        const d = parts[2];
                        const m = parts[1];
                        document.getElementById("setupBirthday").value = `${d}/${m}`;
                    } else {
                        document.getElementById("setupBirthday").value = "";
                    }
                } else {
                    document.getElementById("setupBirthday").value = "";
                }

                document.getElementById("setupBaseDate").value = user.settings.base_date || "";

                document.getElementById("areaSelect").value = user.profile.area || "outros";

                const area = user.profile.area;

                const dsrField = document.getElementById("setupDSR").parentElement;

                if (AREAS_WITHOUT_DSR.includes(area)) {
                    dsrField.style.display = "none";
                    document.getElementById("setupDSR").value = "0";
                } else {
                    dsrField.style.display = "";
                }

                document.getElementById("setupScaleType").value = "";
                document.getElementById("setupScalePattern").value = "";

                if (!AREAS_WITHOUT_DSR.includes(area)) {
                    document.getElementById("setupDSR").value = String(user.settings.dsr ?? 0);
                }

                document.getElementById("setupTheme").value = user.preferences.theme || "auto";

                // aplica preset
                applyAreaPreset(user.profile.area);
            }

            function mostrarSetup() {
                if (overlay) {
                    overlay.classList.remove("active");
                    overlay.hidden = true;
                }

                preencherSetup();
                setupModal.style.display = "flex";
            }
        </script>

        <!-- Bottom Sheet Overlay -->
        <div id="pickerOverlay" hidden>
            <div class="picker-sheet" id="pickerSheet"></div>
        </div>

        <div id="setupModal" class="setup-modal">
            <div class="setup-box">
                <h3>Configurações</h3>

                <label>Nome</label>
                <input type="text" id="setupUserName" placeholder="Seu nome" />

                <label>Aniversário</label>
                <input type="text" id="setupBirthday" placeholder="dd/mm" maxlength="5" />

                <label>Data base da escala</label>
                <input type="date" id="setupBaseDate" />

                <label for="areaSelect">Área de atuação</label>
                <select id="areaSelect"></select>

                <label>Tipo de escala</label>
                <input type="text" id="setupScaleType" />

                <label>Padrão da escala</label>
                <input type="text" id="setupScalePattern" />
                <label>Descanso semanal (DSR)</label>
                <select id="setupDSR">
                    <option value="0">Domingo</option>
                    <option value="1">Segunda</option>
                    <option value="2">Terça</option>
                    <option value="3">Quarta</option>
                    <option value="4">Quinta</option>
                    <option value="5">Sexta</option>
                    <option value="6">Sábado</option>
                </select>

                <label>Tema</label>
                <select id="setupTheme">
                    <option value="auto">Auto</option>
                    <option value="dark">Dark</option>
                    <option value="light">Light</option>
                </select>

                <br /><br />

                <button id="setupSalvar">Salvar</button>
                <button id="setupFechar">Fechar</button>
            </div>
        </div>
    </body>
</html>
